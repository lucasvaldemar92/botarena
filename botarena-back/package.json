{
  "name": "botarena",
  "version": "1.0.0",
  "main": "bot.js",
  "scripts": {
    "start": "node server.js",
    "teste-codigo": "node scripts/teste_codigo.js",
    "teste-seg": "node scripts/teste_seguranca.js",
    "teste-banco": "node scripts/teste_banco.js",
    "teste-e2e": "npx playwright test tests/visual_sync.spec.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "migrate": "node scripts/migrate_add_company_id.js",
    "qa": "node --check server.js src/routes/api.js src/container.js && npm run teste-codigo && npm run teste-seg && npm run test",
    "testes": "npm run qa && npm run teste-banco && npm run teste-e2e"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@sentry/node": "^10.45.0",
    "@sentry/profiling-node": "^10.45.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "jsonwebtoken": "^9.0.3",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.8.3",
    "sqlite3": "^6.0.1",
    "whatsapp-web.js": "^1.34.6",
    "zod": "^4.3.6"
  },
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "jest": "^29.7.0"
  },
  "jest": {
    "testMatch": [
      "**/tests/unit/**/*.spec.js"
    ],
    "collectCoverageFrom": [
      "src/handlers/**/*.js",
      "src/repositories/**/*.js"
    ]
  }
}
