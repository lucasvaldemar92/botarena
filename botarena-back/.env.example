# Database driver: sqlite (default) or postgres
# DB_DRIVER takes precedence over DB_TYPE
DB_DRIVER=sqlite
DB_TYPE=sqlite

# Default database connection string
# SQLite:   sqlite://./database/botarena.db
# Postgres: postgres://user:pass@host:5432/dbname
DATABASE_URL=sqlite://./database/botarena.db

# Sentry DSN (Optional for local dev)
SENTRY_DSN=

# JWT Secret — CHANGE IN PRODUCTION
JWT_SECRET=your-jwt-secret-here

# Environment (development | production)
NODE_ENV=development

# Timezone (Brasilia Time)
TZ=America/Sao_Paulo
